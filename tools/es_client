#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import pathlib
import re
import sys

import requests

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent))
from _common import default_timeout, emit, fail, parse_duration_seconds, tool_config


def kql_to_filter(kql: str) -> dict:
    expression = kql.strip()
    if not expression or expression == "*":
        return {"match_all": {}}

    match = re.fullmatch(r"([A-Za-z0-9_@.-]+)\s*(>=|<=|>|<|=|==)\s*([A-Za-z0-9_./:-]+)", expression)
    if match:
        field, operator, raw_value = match.groups()
        value: str | int | float = raw_value
        if re.fullmatch(r"[0-9]+", raw_value):
            value = int(raw_value)
        elif re.fullmatch(r"[0-9]+\.[0-9]+", raw_value):
            value = float(raw_value)
        if operator in {">=", ">", "<=", "<"}:
            key = {">=": "gte", ">": "gt", "<=": "lte", "<": "lt"}[operator]
            return {"range": {field: {key: value}}}
        return {"term": {field: value}}

    return {"query_string": {"query": expression, "analyze_wildcard": True}}


def main() -> None:
    parser = argparse.ArgumentParser(description="Read-only Elasticsearch/OpenResty log client")
    subparsers = parser.add_subparsers(dest="command", required=True)

    search = subparsers.add_parser("search", help="Search logs")
    search.add_argument("--index", required=True)
    search.add_argument("--kql", required=True)
    search.add_argument("--range", required=True)
    search.add_argument("--size", type=int, default=20)

    args = parser.parse_args()
    config = tool_config("es")
    base_url = str(config.get("base_url") or "")
    if not base_url:
        fail("es base_url is not configured; set tools.es.base_url or ES_URL")
    timeout = default_timeout(config, 20)
    max_size = int(config.get("max_size", 50))
    size = max(1, min(args.size, max_size))
    parse_duration_seconds(args.range)

    headers = {"Content-Type": "application/json"}
    auth = None
    api_key_env = str(config.get("api_key_env") or "ES_API_KEY")
    api_key = os.environ.get(api_key_env, "")
    if api_key:
        headers["Authorization"] = f"ApiKey {api_key}"
    else:
        username = os.environ.get(str(config.get("username_env") or "ES_USERNAME"), "")
        password = os.environ.get(str(config.get("password_env") or "ES_PASSWORD"), "")
        if username or password:
            auth = (username, password)

    query = {
        "size": size,
        "sort": [{"@timestamp": {"order": "desc"}}],
        "query": {
            "bool": {
                "filter": [
                    {"range": {"@timestamp": {"gte": f"now-{args.range}", "lte": "now"}}},
                    kql_to_filter(args.kql),
                ]
            }
        },
    }
    url = base_url.rstrip("/") + f"/{args.index}/_search"

    try:
        response = requests.post(
            url,
            auth=auth,
            headers=headers,
            json=query,
            timeout=timeout,
            verify=bool(config.get("verify_tls", True)),
        )
    except requests.RequestException as exc:
        fail("elasticsearch request failed", exception=str(exc), url=url)

    try:
        body = response.json()
    except ValueError:
        body = response.text[:4000]

    emit(
        {
            "ok": response.ok,
            "source": "elasticsearch",
            "status_code": response.status_code,
            "request": {"method": "POST", "url": url, "body": query},
            "response": body,
        },
        0 if response.ok else 1,
    )


if __name__ == "__main__":
    main()
