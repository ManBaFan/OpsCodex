#!/usr/bin/env python3
from __future__ import annotations

import sys


def has_sequence(args: list[str], sequence: list[str]) -> bool:
    for index in range(len(args) - len(sequence) + 1):
        if args[index : index + len(sequence)] == sequence:
            return True
    return False


